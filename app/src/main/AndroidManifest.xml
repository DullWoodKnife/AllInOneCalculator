        </activity>

        <activity android:name=".activities.ResistanceActivity" />
        <activity android:name=".activities.FuelConsumptionActivity" />
        <activity android:name=".activities.EnergyActivity" />
        <activity android:name=".activities.AgeActivity" />
        <activity android:name=".activities.BMIActivity" />
        <activity android:name=".activities.CarActivity" />
        <activity android:name=".activities.RetirementActivity" />
