<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8E8E8">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#3E3630" />

    <!-- 结果显示区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvRelationPath"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#333333"
            android:textSize="24sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#666666"
            android:textSize="28sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- 第一行: 夫 妻 退格 清空 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnHusband"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="夫"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnWife"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="妻"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnBackspace"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="⌫"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="C"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD" />

        <!-- 第二行: 父 母 兄 弟 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFather"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="父"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnMother"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="母"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnElderBrother"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="兄"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnYoungerBrother"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="弟"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD" />

        <!-- 第三行: 姐 妹 子 女 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnElderSister"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="姐"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnYoungerSister"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="妹"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnSon"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="子"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnDaughter"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="女"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD" />

        <!-- 第四行: 互查 = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMutualCheck"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="互查"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />

            <Button
                android:id="@+id/btnEqual"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="3"
                android:text="="
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:background="#FFA500" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
