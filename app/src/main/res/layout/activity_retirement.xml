<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#5C5046">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#3E3630" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前年龄"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etCurrentAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6B5F55"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:hint="请输入当前年龄"
                android:padding="12dp"
                android:inputType="number"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="计划退休年龄"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etRetirementAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6B5F55"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:hint="请输入计划退休年龄"
                android:padding="12dp"
                android:inputType="number"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="月收入 (元)"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etMonthlyIncome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6B5F55"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:hint="请输入月收入"
                android:padding="12dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="月储蓄比例 (%)"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etSavingsPercent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6B5F55"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:hint="请输入月储蓄比例"
                android:padding="12dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前储蓄 (元)"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etCurrentSavings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6B5F55"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:hint="请输入当前储蓄金额"
                android:padding="12dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="年化收益率 (%)"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etReturnRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6B5F55"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA"
                android:hint="请输入年化收益率"
                android:padding="12dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#8B7D6B"
                android:text="计算退休规划"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="12dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6B5F55"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="16dp"
                android:minHeight="150dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
